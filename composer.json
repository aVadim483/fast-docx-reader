{
  "name": "avadim/fast-docx-reader",
  "description": "Fast and simple DOCX reader for PHP. Extract text and tables from DOCX files, convert DOCX to HTML.",
  "keywords": [
    "php",
    "docx",
    "ooxml",
    "reader",
    "xmlreader",
    "word",
    "msword",
    "parser",
    "reader",
    "import",
    "office",
    "office 2007",
    "libreoffice",
    "document",
    "wordprocessing",
    "extract-text",
    "text-extraction"
  ],
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "avadim\\FastDocxReader\\": "src/"
    }
  },
  "require": {
    "php": ">=7.4",
    "ext-zip": "*",
    "ext-xml": "*",
    "ext-xmlreader": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  }
}
